# Server
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/medipos

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated origins for POS terminal + admin dashboard)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Public base URL of this API (used to build SSLCommerz callback/IPN URLs)
APP_BASE_URL=http://localhost:5000

# Redis (optional) — when set, backs the API rate limiter, the read-through
# cache, and the BullMQ job queue (all degrade gracefully when unset)
# REDIS_URL=redis://127.0.0.1:6379

# Read-through cache TTL in seconds (default 300)
# CACHE_TTL_SECONDS=300

# AWS S3 for invoice/report PDFs (optional — falls back to local disk if unset)
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=medipos-invoices
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_PUBLIC_BASE_URL=https://cdn.example.com   # optional CDN/base override
# LOCAL_STORAGE_DIR=storage                     # local fallback directory

# SSLCommerz subscription payments (optional — gateway disabled if unset)
# SSLCOMMERZ_STORE_ID=your-store-id
# SSLCOMMERZ_STORE_PASSWD=your-store-passwd
# Any value other than "false" means sandbox mode
SSLCOMMERZ_SANDBOX=true

# SMS gateway (optional — logs only if unset). BD HTTP SMS provider.
# SMS_API_URL=https://api.sms-provider.example/sendsms
# SMS_API_KEY=your-sms-api-key
# SMS_SENDER_ID=MediPOS

# Recurring jobs — set ENABLE_SCHEDULER=false to disable entirely (e.g. tests).
# JOB_RUNNER: auto (BullMQ when REDIS_URL set, else node-cron) | cron | bullmq
ENABLE_SCHEDULER=true
# JOB_RUNNER=auto
# JOB_CONCURRENCY=1
